{
  "name": "extract-leads-function",
  "version": "1.0.0",
  "description": "GCP Cloud Function to extract leads using Gemini 2.5 Pro",
  "main": "index.js",
  "scripts": {
    "start": "functions-framework --target=extractLeads",
    "deploy": "gcloud functions deploy extractLeads --runtime nodejs20 --trigger-http --allow-unauthenticated"
  },
  "dependencies": {
    "@google-cloud/functions-framework": "^3.3.0",
    "@google/generative-ai": "^0.2.1",
    "@supabase/supabase-js": "^2.39.3"
  }
}
